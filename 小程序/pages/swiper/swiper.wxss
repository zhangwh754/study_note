.container {
  height: 150px;
}

.container .item {
  height: 100%;
  text-align: center;
  line-height: 150px;
}

.container swiper-item:nth-child(1) .item {
  background-color: lightgreen;
}
.container swiper-item:nth-child(2) .item {
  background-color: lightskyblue;
}
.container swiper-item:nth-child(3) .item {
  background-color: lightcoral;
}
